---
import Tooth from "./icon/Tooth.astro"; 

const { currentPage } = Astro.props;
---

<header id="header">
    <div class="header_hamburger" id="btn_open">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <div class="header_logo_area">
        <div class="header_logo_icon">
            <Tooth />
        </div>
        <div class="header_site_name">
            <span class="header_site_title">Perfección Dental</span>
            <span class="header_site_sub">Camino a la excelencia bucal</span>
        </div>
    </div>

    <div class="header_page_indicator">
        <span class="header_page_dot"></span>
        <span class="header_page_label">{currentPage}</span>
    </div>
</header>

<style>
    #header {
        height: 64px;
        background: #1e293b;
        display: flex;
        align-items: center;
        padding: 0 24px;
        gap: 16px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
    }

    #header::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, #1783db, #38bdf8, #1783db);
    }

    .header_hamburger {
        display: flex;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        padding: 4px;
    }

    .header_hamburger span {
        display: block;
        width: 20px;
        height: 1.5px;
        background: #94a3b8;
        border-radius: 2px;
    }

    .header_logo_area {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .header_logo_icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        background: rgba(23, 131, 219, 0.2);
        border: 0.5px solid rgba(23, 131, 219, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        color: #38bdf8;
    }

    .header_site_name {
        display: flex;
        flex-direction: column;
    }

    .header_site_title {
        font-size: 13px;
        font-weight: 500;
        color: #f1f5f9;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        line-height: 1;
    }

    .header_site_sub {
        font-size: 10px;
        color: #64748b;
        letter-spacing: 0.04em;
        margin-top: 3px;
    }

    .header_page_indicator {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(23, 131, 219, 0.12);
        border: 0.5px solid rgba(23, 131, 219, 0.25);
        border-radius: 20px;
        padding: 4px 12px;
    }

    .header_page_dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #17db31;
    }

    .header_page_label {
        font-size: 11px;
        color: #38bdf8;
        font-weight: 500;
    }
</style>
