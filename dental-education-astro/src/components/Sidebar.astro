---
const { currentPage } = Astro.props;

const nav_items = [
    { label: "Inicio", href: "/", icon: "fas fa-home" },
    { label: "Biblioteca", href: "/biblioteca", icon: "fas fa-book" },
    { label: "Clases", href: "/clases", icon: "fas fa-video" },
];
---

<nav class="sidebar" id="sidebar">
    <div class="sidebar_divider"></div>
    {
        nav_items.map((item) => (
            <a
                href={item.href}
                class={`sidebar_item ${currentPage === item.label ? "sidebar_item_active" : ""}`}
                title={item.label}
            >
                <i class={item.icon} />
                <span class="sidebar_label">{item.label}</span>
            </a>
        ))
    }
</nav>

<style>
    .sidebar {
        width: 68px;
        height: 100%;
        background: #162032;
        position: fixed;
        top: 64px;
        left: 0;
        z-index: 100;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 16px 0;
        gap: 4px;
        border-right: 0.5px solid rgba(23, 131, 219, 0.2);
        transition: width 300ms cubic-bezier(0.785, 0.135, 0.15, 0.86);
        overflow: hidden;
    }

    .sidebar_expanded {
        width: 200px;
        align-items: flex-start;
    }

    .sidebar_divider {
        width: 32px;
        height: 0.5px;
        background: rgba(255, 255, 255, 0.08);
        margin: 8px auto;
        transition: width 300ms;
    }

    .sidebar_expanded .sidebar_divider {
        width: 80%;
    }

    .sidebar_item {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748b;
        border-left: 2px solid transparent;
        transition: all 0.2s;
        overflow: hidden;
        white-space: nowrap;
    }

    .sidebar_item:hover {
        background: rgba(23, 131, 219, 0.1);
        color: #94a3b8;
    }

    .sidebar_item_active {
        background: rgba(23, 131, 219, 0.15);
        color: #38bdf8;
        border-left-color: #1783db;
    }

    .sidebar_label {
        display: none;
        font-size: 13px;
        margin-left: 12px;
    }

    .sidebar_expanded .sidebar_item {
        width: 100%;
        padding: 10px 20px;
        border-radius: 0;
        justify-content: flex-start;
    }

    .sidebar_expanded .sidebar_label {
        display: inline;
    }

    @media screen and (max-width: 760px) {
        .sidebar {
            left: -68px;
        }

        .sidebar_expanded {
            left: 0;
            width: 200px;
        }
    }
</style>
